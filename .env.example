# n8n 認証
N8N_BASIC_AUTH_USER=admin
N8N_API_KEY=                       # n8n UI: Settings → API → Create an API key（make import-workflow で使用）
N8N_BASIC_AUTH_PASSWORD=           # 任意のパスワード
N8N_ENCRYPTION_KEY=                # openssl rand -hex 32 で生成

# 1Password
OP_VAULT_ID=                       # op vault list で確認

# 対象リポジトリ（n8n ワークフロー内で使う）
GITHUB_REPO=                       # 例: owner/repo-name
PROJECT_PATH=                      # 例: /Users/john/Project/
CLAUDE_TIMEOUT_SEC=600             # claude 実行の上限秒数（デフォルト: 600秒）

# Slack 通知
SLACK_BOT_TOKEN=                   # Bot User OAuth Token（xoxb-...）
SLACK_CHANNEL_ID=                  # 通知先チャンネル ID（例: C0XXXXXXXXX）

# 認証トークン
GH_TOKEN=                          # GitHub Fine-grained PAT（PR 作成・Issue 操作用）
CLAUDE_CODE_OAUTH_TOKEN=           # claude setup-token で生成（Max プラン OAuth トークン）
