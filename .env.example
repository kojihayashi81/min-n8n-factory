# n8n 認証
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=           # 任意のパスワード
N8N_ENCRYPTION_KEY=                # openssl rand -hex 32 で生成

# ホスト接続（n8n コンテナ → ホストの claude CLI を呼ぶため）
HOST_SSH_USER=                     # 例: 

# 1Password
OP_VAULT_ID=                       # op vault list で確認

# 対象リポジトリ（n8n ワークフロー内で使う）
GITHUB_REPO=                       # 例: owner/repo-name
PROJECT_PATH=                      # 例: ローカルPC内のプロジェクトのパス
