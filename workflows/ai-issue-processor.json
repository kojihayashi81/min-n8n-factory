{
  "name": "AI Issue Processor（調査フロー）",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "minutes",
              "minutesInterval": 10
            }
          ]
        }
      },
      "id": "node-schedule",
      "name": "Schedule 10min",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [112, 304]
    },
    {
      "parameters": {
        "resource": "repository",
        "owner": "={{ $env.GITHUB_REPO.split('/')[0] }}",
        "repository": "={{ $env.GITHUB_REPO.split('/')[1] }}",
        "limit": 1,
        "getRepositoryIssuesFilters": {
          "labels": "ai-ready",
          "state": "open",
          "sort": "created"
        }
      },
      "id": "node-get-issues",
      "name": "Get oldest ai-ready Issue",
      "type": "n8n-nodes-base.github",
      "typeVersion": 1,
      "position": [304, 304],
      "credentials": {}
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 3
          },
          "conditions": [
            {
              "id": "condition-has-number",
              "leftValue": "={{ !!$json.number }}",
              "rightValue": "",
              "operator": {
                "type": "boolean",
                "operation": "true",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "node-if-exists",
      "name": "If",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [496, 304]
    },
    {
      "parameters": {
        "operation": "edit",
        "owner": "={{ $env.GITHUB_REPO.split('/')[0] }}",
        "repository": "={{ $env.GITHUB_REPO.split('/')[1] }}",
        "issueNumber": "={{ $('Get oldest ai-ready Issue').item.json.number }}",
        "editFields": {
          "labels": [
            {
              "label": "ai-processing"
            }
          ]
        }
      },
      "id": "node-update-label",
      "name": "Set ai-processing label",
      "type": "n8n-nodes-base.github",
      "typeVersion": 1,
      "position": [704, 208],
      "credentials": {}
    },
    {
      "parameters": {
        "command": "={{ 'ssh -o StrictHostKeyChecking=no ' + $env.HOST_SSH_USER + '@host.docker.internal \"cd ' + $env.PROJECT_PATH + ' && claude --print \\\"/investigate ' + $('Get oldest ai-ready Issue').item.json.number + '\\\"\"' }}"
      },
      "id": "node-run-claude",
      "name": "Run Claude Code",
      "type": "n8n-nodes-base.executeCommand",
      "typeVersion": 1,
      "position": [912, 208],
      "notes": "PROJECT_PATH に移動して /investigate {number} Skill を実行。stdout に PR URL が返る。"
    },
    {
      "parameters": {
        "operation": "createComment",
        "owner": "={{ $env.GITHUB_REPO.split('/')[0] }}",
        "repository": "={{ $env.GITHUB_REPO.split('/')[1] }}",
        "issueNumber": "={{ $('Get oldest ai-ready Issue').item.json.number }}",
        "body": "={{ '調査完了しました。結果は以下の Draft PR を確認してください。\\n\\n' + $json.stdout.trim() }}"
      },
      "id": "node-post-comment",
      "name": "Post PR Link to Issue",
      "type": "n8n-nodes-base.github",
      "typeVersion": 1,
      "position": [1104, 208],
      "credentials": {}
    }
  ],
  "connections": {
    "Schedule 10min": {
      "main": [
        [{"node": "Get oldest ai-ready Issue", "type": "main", "index": 0}]
      ]
    },
    "Get oldest ai-ready Issue": {
      "main": [
        [{"node": "If", "type": "main", "index": 0}]
      ]
    },
    "If": {
      "main": [
        [{"node": "Set ai-processing label", "type": "main", "index": 0}]
      ]
    },
    "Set ai-processing label": {
      "main": [
        [{"node": "Run Claude Code", "type": "main", "index": 0}]
      ]
    },
    "Run Claude Code": {
      "main": [
        [{"node": "Post PR Link to Issue", "type": "main", "index": 0}]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}
